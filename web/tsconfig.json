{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "paths": {
      "@go-go-golems/rag-evaluation-site": ["../packages/rag-evaluation-site/src/index.ts"],
      "@go-go-golems/rag-evaluation-site/app": ["../packages/rag-evaluation-site/src/app/index.ts"],
      "@go-go-golems/rag-evaluation-site/ir": ["../packages/rag-evaluation-site/src/widgets/ir.ts"]
    },
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true
  },
  "include": ["src"]
}
