{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "allowImportingTsExtensions": false
  },
  "include": ["src"],
  "exclude": ["src/app/main.tsx"]
}
